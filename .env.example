# ─────────────────────────────────────────────────────────────
# Contact form — Gmail SMTP via the /api/contact route (Nodemailer).
# These are SERVER-ONLY secrets: no NEXT_PUBLIC_ prefix, never exposed
# to the browser, never committed (.env / .env.local are gitignored).
#
# Setup:
#   1. cp .env.example .env.local   (PowerShell: Copy-Item .env.example .env.local)
#   2. Fill in the values below.
#   3. For production, add the SAME variables in the Vercel dashboard:
#      Project → Settings → Environment Variables (All Environments).
#
# App password (requires 2-Step Verification on the Google account):
#   Google Account → Security → 2-Step Verification → App passwords.
#   Paste it WITHOUT the spaces Google displays.
# ─────────────────────────────────────────────────────────────

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=archi061234@gmail.com
SMTP_PASS=your16charapppassword

# optional — where form messages are delivered (defaults to SMTP_USER)
CONTACT_TO=archi061234@gmail.com
