# ─────────────────────────────────────────────────────────────
# EmailJS — contact form delivery (https://dashboard.emailjs.com)
# Free tier: 200 emails/month. These are PUBLIC client-side IDs and
# are safe to expose in a static bundle (the form posts from the browser).
#
# Setup:
#   1. cp .env.example .env.local   (PowerShell: Copy-Item .env.example .env.local)
#   2. Fill the three values below from your EmailJS dashboard.
#   3. For production, add the SAME three as GitHub repo secrets
#      (Settings → Secrets and variables → Actions).
# ─────────────────────────────────────────────────────────────

# Email Services → Add New Service → Gmail  → e.g. service_xxxxxxx
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxx

# Email Templates → Create New Template  → e.g. template_xxxxxxx
# Template variables must match the form field names: name, email, subject, message
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_xxxxxxx

# Account → General → API Keys → Public Key  (NEVER use the Private Key here)
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxx
